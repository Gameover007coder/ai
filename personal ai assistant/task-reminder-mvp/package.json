{
  "name": "task-reminder-mvp",
  "version": "1.0.0",
  "private": true,
  "description": "Free, unlimited task & appointment reminder app with screen overlay widgets",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter database db:generate",
    "db:migrate": "pnpm --filter database db:migrate",
    "db:studio": "pnpm --filter database db:studio",
    "api:dev": "pnpm --filter api dev",
    "web:dev": "pnpm --filter web dev",
    "extension:build": "pnpm --filter extension build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
